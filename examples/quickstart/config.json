{
  "name": "quickstart_cube",
  "input": {
    "path": "input/quickstart_cube.tif",
    "voxel_size": 1.0,
    "generate": {
      "kind": "binary_cube",
      "shape": [16, 16, 16],
      "bounds": [[4, 12], [4, 12], [4, 12]]
    }
  },
  "output_dir": "output",
  "outputs": ["stl", "dat", "properties"],
  "properties": ["surface_area", "closed_volume", "volume_by_area", "porosity"]
}
